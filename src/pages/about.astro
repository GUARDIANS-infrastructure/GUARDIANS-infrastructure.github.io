---
import MainLayout from "../layouts/MainLayout.astro";
import { aboutContent } from "../data/about";
import LucideIcon from "../components/LucideIcon.astro";
import { withBase } from "../utils/paths";

const hrefFor = (href: string) => href.startsWith("/") ? withBase(href) : href;
---

<MainLayout
  title={aboutContent.meta.title}
  pathname={Astro.url.pathname}
  description={aboutContent.meta.description}
>
  <section class="page-header stack-md">
    <span class="eyebrow">{aboutContent.header.eyebrow}</span>
    <h1>{aboutContent.header.title}</h1>
    <p>{aboutContent.header.intro}</p>
  </section>

  <section class="section section-card stack-md">
    <div class="section-heading">
      <div>
        <span class="eyebrow">{aboutContent.overview.eyebrow}</span>
        <h2 class="section-title">{aboutContent.overview.title}</h2>
      </div>
    </div>
    <blockquote class="pull-quote">
      <p>{aboutContent.overview.quote.text}</p>
      <cite>
        <a href={aboutContent.overview.quote.href}>{aboutContent.overview.quote.source}</a>
      </cite>
    </blockquote>
    {aboutContent.overview.paragraphs.map((paragraph) => (
      <p>
        {paragraph.map((segment) =>
          typeof segment === "string"
            ? segment
            : <a href={hrefFor(segment.href)}>{segment.text}</a>
        )}
      </p>
    ))}
  </section>

  <section class="section section-card stack-md">
    <div class="section-heading">
      <div>
        <span class="eyebrow">{aboutContent.coordination.eyebrow}</span>
        <h2 class="section-title">{aboutContent.coordination.title}</h2>
      </div>
    </div>
    <p>
      {aboutContent.coordination.paragraph.map((segment) =>
        typeof segment === "string"
          ? segment
          : <a href={hrefFor(segment.href)}>{segment.text}</a>
      )}
    </p>
    <figure class="section-photo">
      <img
        src={withBase("/assets/meeting_02_welcome.jpg")}
        alt="GUARDIANS partners attending a 2025 Brisbane meeting session"
        loading="lazy"
      />
    </figure>
  </section>

  <section class="section section-card">
    <div class="section-heading">
      <div>
        <span class="eyebrow">{aboutContent.timeline.eyebrow}</span>
        <h2 class="section-title">{aboutContent.timeline.title}</h2>
      </div>
    </div>
    <div class="timeline">
      {aboutContent.timeline.items.map((item) => (
        <div class="timeline__item">
          <LucideIcon name={item.icon} class="timeline__icon" />
          <div>
            <strong>{item.title}</strong>
            <p>
              {item.content.map((segment) =>
                typeof segment === "string"
                  ? segment
                  : <a href={hrefFor(segment.href)}>{segment.text}</a>
              )}
            </p>
          </div>
        </div>
      ))}
    </div>
  </section>

  <section class="section section-card stack-md">
    <div class="section-heading">
      <div>
        <span class="eyebrow">{aboutContent.funding.eyebrow}</span>
        <h2 class="section-title">{aboutContent.funding.title}</h2>
      </div>
    </div>
    <p>
      {aboutContent.funding.paragraph.map((segment) =>
        typeof segment === "string"
          ? segment
          : <a href={hrefFor(segment.href)}>{segment.text}</a>
      )}
    </p>
  </section>

  <section class="section section-card stack-md">
    <div class="section-heading">
      <div>
        <span class="eyebrow">{aboutContent.related.eyebrow}</span>
        <h2 class="section-title">{aboutContent.related.title}</h2>
      </div>
    </div>
    <div class="grid grid-3 related-paths">
      {aboutContent.related.cards.map((card) => (
        <article class="card">
          <h3>{card.title}</h3>
          <p>{card.description}</p>
          <a class="card__link" href={hrefFor(card.href)}>{card.linkLabel}</a>
        </article>
      ))}
    </div>
  </section>
</MainLayout>
