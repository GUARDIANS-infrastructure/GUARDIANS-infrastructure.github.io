---
import { getCollection } from "astro:content";
import MainLayout from "../layouts/MainLayout.astro";
import { homeContent } from "../data/home";
import { partnerLogos } from "../data/logos";
import { capabilities, site } from "../data/site";
import { withBase } from "../utils/paths";

const activityItems = (await getCollection("activity"))
  .sort((first, second) => second.data.date.getTime() - first.data.date.getTime())
  .slice(0, 3);
---

<MainLayout title="Home" pathname={Astro.url.pathname}>
  <section class="hero">
    <div class="hero__body">
      <span class="eyebrow">{homeContent.hero.eyebrow}</span>
      <h1>{site.description}</h1>
      <p class="hero__lead">{homeContent.hero.intro}</p>
      <div class="button-row">
        <a class="button button-primary" href={withBase(homeContent.hero.primaryCta.href)}>
          {homeContent.hero.primaryCta.label}
        </a>
        <a class="button button-secondary" href={withBase(homeContent.hero.secondaryCta.href)}>
          {homeContent.hero.secondaryCta.label}
        </a>
      </div>
    </div>
  </section>

  <section class="section section-card">
    {(homeContent.journey.eyebrow || homeContent.journey.title) && (
      <div class="section-heading">
        <div>
          {homeContent.journey.eyebrow && <span class="eyebrow">{homeContent.journey.eyebrow}</span>}
          {homeContent.journey.title && <h2 class="section-title">{homeContent.journey.title}</h2>}
        </div>
      </div>
    )}
    {homeContent.journey.intro && <p class="lede">{homeContent.journey.intro}</p>}
    <div class="journey-figure">
      <img src={withBase(homeContent.journey.image.src)} alt={homeContent.journey.image.alt} />
    </div>
  </section>

  <section class="section section-card">
    <div class="section-heading">
      <div>
        <span class="eyebrow">{homeContent.why.eyebrow}</span>
        <h2 class="section-title">{homeContent.why.title}</h2>
      </div>
    </div>
    <div class="stack-md">
      {homeContent.why.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
      <a class="card__link" href={withBase(homeContent.why.link.href)}>{homeContent.why.link.label}</a>
    </div>
  </section>

  <section class="section section-card">
    <div class="section-heading">
      <div>
        <span class="eyebrow">{homeContent.capabilities.eyebrow}</span>
        <h2 class="section-title">{homeContent.capabilities.title}</h2>
      </div>
      {homeContent.capabilities.intro && <p class="lede">{homeContent.capabilities.intro}</p>}
    </div>
    <div class="grid grid-3">
      {
        capabilities.map((capability) => (
          <article class="card">
            <h3>{capability.name}</h3>
            <p>{capability.summary}</p>
            <a class="card__link" href={withBase(`/services-resources?capability=${encodeURIComponent(capability.name)}#catalogue`)}>
              {homeContent.capabilities.itemLinkLabel}
            </a>
          </article>
        ))
      }
    </div>
  </section>

  <section class="section section-card">
    <div class="section-heading">
      <div>
        <span class="eyebrow">{homeContent.partners.eyebrow}</span>
        <h2 class="section-title">{homeContent.partners.title}</h2>
      </div>
      <a class="card__link" href={withBase(homeContent.partners.link.href)}>{homeContent.partners.link.label}</a>
    </div>
    <p class="lede">{homeContent.partners.intro}</p>
    <div class="partner-logo-strip">
      {partnerLogos.map((logo) => (
        <div class={`logo-tile ${logo.tileClassName ?? ""}`.trim()}>
          <img class={logo.className} src={withBase(logo.src)} alt={logo.alt} />
        </div>
      ))}
    </div>
  </section>

  <section class="section section-card">
    <div class="section-heading">
      <div>
        <span class="eyebrow">{homeContent.activity.eyebrow}</span>
        <h2 class="section-title">{homeContent.activity.title}</h2>
      </div>
    </div>
    <div class="grid grid-3">
      {activityItems.map((item) => (
        <article class="card">
          <h3>{item.data.title}</h3>
          <p>{item.data.summary}</p>
          <a class="card__link" href={withBase(item.data.href)}>{homeContent.activity.itemLinkLabel}</a>
        </article>
      ))}
    </div>
  </section>

  <section class="section section-card">
    <div class="section-heading">
      <div>
        <span class="eyebrow">{homeContent.nextStep.eyebrow}</span>
        <h2 class="section-title">{homeContent.nextStep.title}</h2>
      </div>
    </div>
    <p class="lede">{homeContent.nextStep.intro}</p>
    <div class="cta-row">
      <a class="button button-primary" href={withBase(homeContent.nextStep.primaryCta.href)}>{homeContent.nextStep.primaryCta.label}</a>
      <a class="button button-secondary" href={withBase(homeContent.nextStep.secondaryCta.href)}>{homeContent.nextStep.secondaryCta.label}</a>
    </div>
  </section>
</MainLayout>
