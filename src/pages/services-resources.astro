---
import { getCollection } from "astro:content";
import CatalogueFilters from "../components/CatalogueFilters";
import MainLayout from "../layouts/MainLayout.astro";
import { capabilities, outputTypes, site, statusValues, visibilityValues } from "../data/site";

const catalogue = await getCollection("catalogue");

const items = catalogue.map((item) => ({
  slug: item.slug,
  title: item.data.title,
  summary: item.data.summary,
  userValue: item.data.userValue,
  capability: item.data.capability,
  outputType: item.data.outputType,
  status: item.data.status,
  visibility: item.data.visibility,
  leadPartner: item.data.leadPartner,
  contributingPartners: item.data.contributingPartners,
  contributionTypes: item.data.contributionTypes,
  relatedPartners: item.data.relatedPartners,
  href: item.data.href,
  draftInferred: item.data.draftInferred,
  intendedUsers: item.data.intendedUsers
}));

const partners = [...new Set(catalogue.flatMap((item) => [item.data.leadPartner, ...item.data.contributingPartners]))].sort();
---

<MainLayout
  title="Services & resources"
  pathname={Astro.url.pathname}
  description="Discover GUARDIANS services, infrastructure components, guidance, reports, and other draft programme outputs."
>
  <section class="page-header stack-md">
    <span class="eyebrow">Catalogue</span>
    <h1>Services &amp; resources</h1>
    <p>
      This catalogue brings together public-facing services and the enabling resources, infrastructure components, guidance, publications, and pilot outputs that support GUARDIANS delivery.
    </p>
    <p class="draft-note">
      Catalogue entries are draft sample records inferred from the supplied background documents. Unsupported items are intentionally omitted rather than guessed.
    </p>
  </section>

  <section class="section section-card stack-md" id="catalogue">
    <div class="section-heading">
      <div>
        <span class="eyebrow">Findability</span>
        <h2 class="section-title">Filter the catalogue</h2>
      </div>
      <a class="card__link" href="/contact">Can’t find what you need?</a>
    </div>
    <CatalogueFilters
      client:load
      items={items}
      capabilities={capabilities.map((item) => item.name)}
      outputTypes={outputTypes}
      statusValues={statusValues}
      visibilityValues={visibilityValues}
      partners={partners}
    />
  </section>

  <section class="section section-card">
    <div class="section-heading">
      <div>
        <span class="eyebrow">Use the catalogue</span>
        <h2 class="section-title">Interpreting status and visibility</h2>
      </div>
    </div>
    <div class="grid grid-3">
      <article class="card">
        <h3>Status</h3>
        <p>Availability is expressed separately from access conditions so pilot and in-development items are not mistaken for production services.</p>
      </article>
      <article class="card">
        <h3>Visibility / access</h3>
        <p>Some entries are public, some support limited cohorts, and some are internal enabling components that still matter for program transparency.</p>
      </article>
      <article class="card">
        <h3>Partner attribution</h3>
        <p>Each item names the lead partner and can link back to the partner contribution index for broader delivery context.</p>
      </article>
    </div>
  </section>

  <section class="section section-card">
    <div class="section-heading">
      <div>
        <span class="eyebrow">Next step</span>
        <h2 class="section-title">Need a different pathway?</h2>
      </div>
    </div>
    <div class="cta-row">
      <a class="button button-primary" href={`mailto:${site.contactEmail}`}>Contact the GUARDIANS team</a>
      <a class="button button-secondary" href="/partners-contributions">See partner contributions</a>
    </div>
  </section>
</MainLayout>
