---
import { getCollection } from "astro:content";
import CatalogueFilters from "../components/CatalogueFilters";
import MainLayout from "../layouts/MainLayout.astro";
import { capabilities, outputTypes, site, statusValues, visibilityValues } from "../data/site";
import { withBase } from "../utils/paths";

const catalogue = await getCollection("catalogue");

const items = catalogue.map((item) => ({
  slug: item.slug,
  title: item.data.title,
  summary: item.data.summary,
  userValue: item.data.userValue,
  capability: item.data.capability,
  outputType: item.data.outputType,
  status: item.data.status,
  visibility: item.data.visibility,
  leadOrganisations: item.data.leadOrganisations,
  contributingOrganisations: item.data.contributingOrganisations,
  contributionTypes: item.data.contributionTypes,
  href: item.data.href,
  intendedUsers: item.data.intendedUsers,
  featured: item.data.featured,
}));

---

<MainLayout
  title="Services & resources"
  pathname={Astro.url.pathname}
  description="Discover GUARDIANS services, infrastructure components, guidance, reports, and other program outputs."
>
  <section class="page-header stack-md">
    <span class="eyebrow">Catalogue</span>
    <h1>Services &amp; resources</h1>
    <p>
      This catalogue brings together public-facing services and the enabling resources, infrastructure components, guidance, publications, and pilot outputs that support GUARDIANS delivery.
    </p>
  </section>

  <section class="section section-card stack-md" id="catalogue">
    <div class="section-heading">
      <div>
        <span class="eyebrow">Findability</span>
        <h2 class="section-title">Filter the catalogue</h2>
      </div>
      <a class="card__link" href={withBase("/contact")}>Can’t find what you need?</a>
    </div>
    <CatalogueFilters
      client:load
      items={items}
      capabilities={capabilities.map((item) => item.name)}
      outputTypes={outputTypes}
      statusValues={statusValues}
      visibilityValues={visibilityValues}
    />
  </section>

  <section class="section section-card">
    <div class="section-heading">
      <div>
        <span class="eyebrow">Next step</span>
        <h2 class="section-title">Need a different pathway?</h2>
      </div>
    </div>
    <div class="cta-row">
      <a class="button button-primary" href={`mailto:${site.contactEmail}`}>Contact the GUARDIANS team</a>
      <a class="button button-secondary" href={withBase("/partners-contributions")}>See partner contributions</a>
    </div>
  </section>
</MainLayout>
