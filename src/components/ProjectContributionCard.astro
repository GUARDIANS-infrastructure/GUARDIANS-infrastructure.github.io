---
import { projectOrganisationLogos } from "../data/logos";
import type { DeliveryUnitName, OrganisationName } from "../data/vocabularies";
import { withBase } from "../utils/paths";

interface Props {
  project: {
    projectSlug: string;
    title: string;
    leadOrganisations: OrganisationName[];
    deliveryUnits?: DeliveryUnitName[];
    collaboratingOrganisations?: OrganisationName[];
    description: string;
    capabilityAreas: string[];
  };
}

const { project } = Astro.props;
const hasDeliveryUnits = Boolean(project.deliveryUnits?.length);
const hasCollaboratingOrganisations = Boolean(project.collaboratingOrganisations?.length);
---

<article class="project-card">
  <div class="project-card__header">
    <div class="project-card__logos" aria-label="Lead partner organisations">
      {project.leadOrganisations.map((organisation) => {
        const logo = projectOrganisationLogos[organisation];

        return (
          <div class="project-card__logo-tile">
            {logo ? (
              <img class={logo.className} src={withBase(logo.src)} alt={logo.alt} />
            ) : (
              <span>{organisation}</span>
            )}
          </div>
        );
      })}
    </div>
    <div class="project-card__title">
      <h3>{project.title}</h3>
    </div>
  </div>
  <div class="project-card__body">
    <p>{project.description}</p>
    {(hasDeliveryUnits || hasCollaboratingOrganisations) && (
      <p class="project-card__meta">
        {hasDeliveryUnits && (
          <>
            <strong>Delivery unit{project.deliveryUnits.length === 1 ? "" : "s"}:</strong>{" "}
            {project.deliveryUnits.join(", ")}
          </>
        )}
        {hasDeliveryUnits && hasCollaboratingOrganisations ? " · " : ""}
        {hasCollaboratingOrganisations && (
          <>
            <strong>Collaborating organisation{project.collaboratingOrganisations.length === 1 ? "" : "s"}:</strong>{" "}
            {project.collaboratingOrganisations.join(", ")}
          </>
        )}
      </p>
    )}
    <div class="meta-list">
      {project.capabilityAreas.map((area) => (
        <a
          class="chip chip-link"
          href={withBase(`/services-resources?capability=${encodeURIComponent(area)}&project=${encodeURIComponent(project.projectSlug)}#catalogue`)}
        >
          {area}
        </a>
      ))}
    </div>
  </div>
</article>
