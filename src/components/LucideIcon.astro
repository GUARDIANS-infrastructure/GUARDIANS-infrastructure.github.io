---
import { lucideIconMarkup, type LucideIconName } from "../icons/lucide";

interface Props {
  name: LucideIconName;
  class?: string;
}

const { name, class: className } = Astro.props;
---

<svg
  class:list={["lucide-icon", className]}
  aria-hidden="true"
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="2"
  stroke-linecap="round"
  stroke-linejoin="round"
  set:html={lucideIconMarkup[name]}
/>
