---
interface Props {
  item: {
    id: string;
    slug: string;
    data: {
      title: string;
      summary: string;
      userValue: string;
      capability: string;
      outputType: string;
      status: string;
      visibility: string;
      leadPartner: string;
      contributingPartners: string[];
      contributionTypes: string[];
      href?: string;
      relatedPartners: string[];
      draftInferred: boolean;
    };
  };
}

const { item } = Astro.props;
---

<article class="card" id={item.slug}>
  <div class="chips">
    <span class="badge badge-strong">{item.data.status}</span>
    <span class="badge">{item.data.visibility}</span>
    <span class="badge">{item.data.outputType}</span>
    {item.data.draftInferred && <span class="badge">Draft</span>}
  </div>
  <div class="stack-md">
    <h3>{item.data.title}</h3>
    <p>{item.data.summary}</p>
    <p><strong>User value:</strong> {item.data.userValue}</p>
  </div>
  <div class="stack-md">
    <div class="meta-list">
      <span class="chip">{item.data.capability}</span>
      <span class="chip">Lead: {item.data.leadPartner}</span>
    </div>
    {item.data.contributingPartners.length > 0 && (
      <p>
        <strong>Contributing partners:</strong> {item.data.contributingPartners.join(", ")}
      </p>
    )}
    <p>
      <strong>Contribution types:</strong> {item.data.contributionTypes.join(", ")}
    </p>
  </div>
  <div class="card__footer">
    <div class="meta-list">
      {item.data.relatedPartners.map((partner) => (
        <a class="chip" href={`/partners-contributions#${partner}`}>
          Partner entry
        </a>
      ))}
    </div>
    <a class="card__link" href={item.data.href ?? "/contact"}>
      {item.data.href ? "Use or view resource" : "Contact about this item"}
    </a>
  </div>
</article>
