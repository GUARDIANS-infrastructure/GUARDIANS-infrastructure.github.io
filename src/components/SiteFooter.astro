---
import { funderLogos } from "../data/logos";
import { site } from "../data/site";
import { withBase } from "../utils/paths";
---

<footer class="site-footer">
  <div class="shell">
    <div class="site-footer__meta">
      <nav class="site-footer__logos" aria-label="Funder logos">
        {funderLogos.map((logo) => (
          <a
            class="site-footer__logo-tile"
            href={logo.href}
            target="_blank"
            rel="noreferrer"
          >
            <img src={withBase(logo.src)} alt={logo.alt} />
          </a>
        ))}
      </nav>
      <div class="site-footer__meta-text">
        {site.footerAcknowledgements.map((line) => (
          <p>
            {line.map((segment) =>
              typeof segment === "string"
                ? segment
                : <a href={segment.href}>{segment.text}</a>
            )}
          </p>
        ))}
      </div>
    </div>
  </div>
</footer>
